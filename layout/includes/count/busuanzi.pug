.busuanzi
  script(async src="//cdn.busuanzi.cc/busuanzi/3.6.9/busuanzi.min.js" defer)
  if(!is_post())
    if(theme.busuanzi.site_today_uv)
      span#busuanzi_container_site_today_uv!= theme.busuanzi.site_today_uv_header
        span#busuanzi_value_site_today_uv 
          i.fa-solid.fa-spinner.fa-spin
        span!=theme.busuanzi.site_today_uv_footer
    if(theme.busuanzi.site_today_pv)
      span.footer-separator |
      span#busuanzi_container_site_today_pv!= theme.busuanzi.site_today_pv_header
        span#busuanzi_value_site_today_pv 
          i.fa-solid.fa-spinner.fa-spin
        span!=theme.busuanzi.site_today_pv_footer
    
    br

    if(theme.busuanzi.site_uv)
      span#busuanzi_container_site_uv!= theme.busuanzi.site_uv_header
        span#busuanzi_value_site_uv 
          i.fa-solid.fa-spinner.fa-spin
        span!=theme.busuanzi.site_uv_footer
    if(theme.busuanzi.site_pv)
      span.footer-separator |
      span#busuanzi_container_site_pv!= theme.busuanzi.site_pv_header
        span#busuanzi_value_site_pv 
          i.fa-solid.fa-spinner.fa-spin
        span!=theme.busuanzi.site_pv_footer
  else
    if(theme.busuanzi.page_pv)
      span#busuanzi_container_page_pv!= theme.busuanzi.page_pv_header
        span#busuanzi_value_page_pv
          i.fa-solid.fa-spinner.fa-spin
        span!=theme.busuanzi.page_pv_footer
    else
      if(theme.busuanzi.site_uv)
        span#busuanzi_container_site_uv!= theme.busuanzi.site_uv_header
          span#busuanzi_value_site_uv 
            i.fa-solid.fa-spinner.fa-spin
          span!=theme.busuanzi.site_uv_footer
      if(theme.busuanzi.site_pv)
        span.footer-separator |
          span#busuanzi_container_site_pv!= theme.busuanzi.site_pv_header
            span#busuanzi_value_site_pv 
             i.fa-solid.fa-spinner.fa-spin
          span!=theme.busuanzi.site_pv_footer
      if(theme.busuanzi.site_today_uv)
        span#busuanzi_container_site_today_uv!= theme.busuanzi.site_today_uv_header
          span#busuanzi_value_site_today_uv 
            i.fa-solid.fa-spinner.fa-spin
          span!=theme.busuanzi.site_today_uv_footer
      if(theme.busuanzi.site_today_pv)
        span.footer-separator |
        span#busuanzi_container_site_today_pv!= theme.busuanzi.site_today_pv_header
          span#busuanzi_value_site_today_pv 
            i.fa-solid.fa-spinner.fa-spin
          span!=theme.busuanzi.site_today_pv_footer 
